rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. GLOBAL SAFETY NET - Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. PRIMITIVES AND HARDENED HELPERS
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // Bootstrapped administrator checking via explicit lookups
    function isAdmin() {
      return isEmailVerified() && (
        request.auth.token.email == "kanika9694@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 2. VALIDATION BLUEPRINTS (The Anti-Update-Gap)
    function isValidService(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 128
        && data.desc is string && data.desc.size() <= 1000
        && data.price is string && data.price.size() <= 32
        && data.duration is string && data.duration.size() <= 32
        && data.active is bool;
    }

    function isValidLead(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 128
        && data.phone is string && data.phone.size() <= 32
        && data.email is string && data.email.size() <= 128
        && data.service is string && data.service.size() <= 128
        && data.status is string && data.status.size() <= 32
        && data.message is string && data.message.size() <= 2000
        && data.notes is string && data.notes.size() <= 5000
        && data.createdAt is string && data.createdAt.size() <= 64;
    }

    function isValidBlogPost(data) {
      return data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 256
        && data.excerpt is string && data.excerpt.size() <= 1000
        && data.content is string && data.content.size() <= 100000
        && data.status is string && (data.status == 'draft' || data.status == 'published');
    }

    function isValidFAQ(data) {
      return data.id is string && data.id.size() <= 128
        && data.q is string && data.q.size() <= 512
        && data.a is string && data.a.size() <= 4096;
    }

    function isValidSettings(data) {
      return data.mode is string && (data.mode == 'light' || data.mode == 'dark')
        && data.palette is string && data.palette.size() <= 64
        && data.borderRadius is string && data.borderRadius.size() <= 64
        && data.shadows is string && data.shadows.size() <= 64;
    }

    // 4. COLLECTION ROUTINGS & PATH VARIABLE HARDENING
    
    // Website Settings Collection
    match /settings/{settingId} {
      allow read: if true; // Public site reads settings for branding/menu loading
      allow write: if isAdmin() && isValidId(settingId) && isValidSettings(incoming());
    }

    // Services Catalog Collection
    match /services/{serviceId} {
      allow read: if true; // Anyone can read services
      allow create, delete: if isAdmin() && isValidId(serviceId) && isValidService(incoming());
      allow update: if isAdmin() && isValidId(serviceId) && isValidService(incoming());
    }

    // CRM Leads & Bookings Collection
    match /leads/{leadId} {
      // Admin can do anything; client can create leads (submit inquiry) but cannot browse others
      allow create: if isValidId(leadId) && isValidLead(incoming());
      allow get: if isAdmin() && isValidId(leadId);
      allow list: if isAdmin(); // NO BLANKET READS - Admin can list and filter all inquiries
      allow delete: if isAdmin() && isValidId(leadId);
      
      // Updates are divided into named Actions via diff() affectedKeys
      allow update: if isValidId(leadId) && (
        isAdmin() || (
          // Allow client or staff to only append notes or update lead status
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'notes']) &&
          incoming().status is string && incoming().status.size() <= 32 &&
          incoming().notes is string && incoming().notes.size() <= 5000
        )
      );
    }

    // Blogs Collection
    match /blog/{postId} {
      allow read: if true; // Public blogs
      allow write: if isAdmin() && isValidId(postId) && isValidBlogPost(incoming());
    }

    // FAQs Collection
    match /faqs/{faqId} {
      allow read: if true; // Public FAQ
      allow write: if isAdmin() && isValidId(faqId) && isValidFAQ(incoming());
    }
  }
}
